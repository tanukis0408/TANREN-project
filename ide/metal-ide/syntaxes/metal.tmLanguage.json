{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Metal",
  "scopeName": "source.metal",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-call"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.metal",
          "match": "--.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.metal",
          "match": "\\b(fn|if|elif|else|for|in|while|loop|end|return|break|next|let|match|use|struct|class)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.metal",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.metal",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.metal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.metal",
              "match": "\\\\[ntr\"\\\\]"
            }
          ]
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.metal",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.metal",
          "match": "(\\+|\\-|\\*\\*|\\*|/|%|==|!=|<=|>=|<|>|=|\\.\\.|\\||\\|>)"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.metal",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_!?]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
