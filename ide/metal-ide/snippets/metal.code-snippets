      "end"
    ],
    "description": "Create a Metal function"
  },
  "If / Elif / Else": {
    "prefix": "if",
    "body": [
      "if ${1:condition}",
      "  ${2:say \"then\"}",
      "elif ${3:other_condition}",
      "  ${4:say \"elif\"}",
      "else",
      "  ${5:say \"else\"}",
      "end"
    ],
    "description": "Create if-elif-else block"
  },
  "For Range Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:1}..${3:10}",
