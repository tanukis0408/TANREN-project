      "end"
    ],
    "description": "Create range-based for loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "  ${2:say \"tick\"}",
      "end"
    ],
    "description": "Create while loop"
  },
