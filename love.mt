fn love(name)
  say "TANUKIS любит " + name
end

fn truelove(name1, name2)
  say name1 + " + " + name2 + " = навсегда"
end

fn arch_art()
  say "        /\        "
  say "       /  \       "
  say "      /\    \      "
  say "     /  \    \     "
  say "    / /\ \  / \    "
  say "   / /  \ \/   \   "
  say "  / /    \  /\  \  "
  say " / /      \/  \  \ "
  say "//__________\  \__\"
end

arch_art()
love("Arch Linux")
truelove("TANUKIS", "Arch Linux")